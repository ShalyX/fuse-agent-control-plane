# Required for real Circle Phase 0
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# Select the inference provider: anthropic (default) or openrouter
FUSE_PROVIDER=anthropic

# Direct official Anthropic Messages API inference
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter OpenAI-compatible inference
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_SITE_URL=https://fuse-agent-control-plane.vercel.app
OPENROUTER_APP_NAME=Fuse

# Circle Gateway payer/seller
FUSE_PAYER_ADDRESS=0x68abdce904bd68c53b0daf43c9b83a5aa8c0b2f7
FUSE_SELLER_ADDRESS=0xa1984d65d411bb30bfd5fb6148c61fcc3cd3332c

# Reservation tariff. Direct Anthropic defaults to 3.00/15.00; reviewed OpenRouter
# Claude Sonnet 4.6 routing uses the conservative 3.30/16.50 maximum observed tariff.
FUSE_INPUT_USD_PER_M=3.30
FUSE_OUTPUT_USD_PER_M=16.50
PORT=8787
