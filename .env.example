# Select the inference provider: anthropic (default) or openrouter
FUSE_PROVIDER=anthropic

# Direct official Anthropic Messages API inference
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter OpenAI-compatible inference
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_SITE_URL=https://fuse-agent-control-plane.vercel.app
OPENROUTER_APP_NAME=Fuse

# Circle Gateway payer/seller
FUSE_PAYER_ADDRESS=0x68abdce904bd68c53b0daf43c9b83a5aa8c0b2f7
FUSE_SELLER_ADDRESS=0xa1984d65d411bb30bfd5fb6148c61fcc3cd3332c

# Reservation tariff. Direct Anthropic defaults to 3.00/15.00; reviewed OpenRouter
# Claude Sonnet 4.6 routing uses the conservative 3.30/16.50 maximum observed tariff.
FUSE_INPUT_USD_PER_M=3.30
FUSE_OUTPUT_USD_PER_M=16.50
PORT=8787

# Separate signer service. Deploy independently from the control plane; never share its
# Circle authority with the public application runtime. Circle credentials must belong
# to a LIVE_API entity with the configured LIVE developer-controlled Base wallet.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
SIGNER_ORGANIZATION_ID=
SIGNER_CALLER_ID=fuse-control-plane
SIGNER_AUTH_TOKEN=
SIGNER_DATABASE_URL=
SIGNER_WALLET_ID=
SIGNER_WALLET_ADDRESS=
SIGNER_GATEWAY_WALLET_ADDRESS=
SIGNER_ALLOWED_PAY_TO_ADDRESS=
SIGNER_CHAIN_ID=8453
SIGNER_MAXIMUM_ATOMIC=1000
SIGNER_MAXIMUM_TOTAL_ATOMIC=1000

# Operator and bounded Base-mainnet readiness checks. These commands inspect state only;
# they do not submit a transaction.
FUSE_BASE_URL=https://fuse-agent-control-plane.vercel.app
FUSE_ADMIN_TOKEN=
FUSE_MAINNET_PAYER_ADDRESS=
FUSE_MAINNET_CAP_USDC_ATOMIC=1000
SHALY_SIGNER_URL=
SHALY_SIGNER_AUTH_TOKEN=
SHALY_SIGNER_GATEWAY_WALLET_ADDRESS=
SHALY_SIGNER_ALLOWED_PAY_TO_ADDRESS=
