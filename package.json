{
  "name": "fuse-agent-control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "api/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "node --env-file=.env --import tsx src/server.ts",
    "demo": "tsx scripts/demo.ts",
    "identity:bootstrap": "tsx scripts/bootstrap-identity.ts",
    "ops:check": "tsx scripts/check-operations.ts",
    "ops:reconcile": "tsx scripts/reconcile-inference.ts",
    "mainnet:readiness": "tsx scripts/check-mainnet-readiness.ts",
    "smoke:production": "tsx scripts/smoke-production.ts",
    "migrate:provider-config": "tsx scripts/migrate-provider-config.ts",
    "shadow:retry": "tsx scripts/process-shadow-queue.ts",
    "check": "npm test && npm run build"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.8.0",
    "@circle-fin/smart-contract-platform": "^10.8.0",
    "@circle-fin/x402-batching": "^3.2.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "express": "^5.1.0",
    "pg": "^8.22.0",
    "viem": "^2.55.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "pg-mem": "^3.0.14",
    "solc": "^0.8.36",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
